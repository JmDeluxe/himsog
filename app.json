{
  "expo": {
    "name": "Himsog",
    "slug": "Himsog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/himsog-logo.png",
    "scheme": "himsog",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/himsog-logo.png",
        "backgroundColor": "#6C5CE7"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.himsog.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#6C5CE7",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 1
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Himsog to access your camera to scan product barcodes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Himsog to access your photos to scan barcodes from saved images."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a414b21f-516d-4831-8c96-fe27c5feb84a"
      }
    },
    "owner": "jmdevelopment"
  }
}
